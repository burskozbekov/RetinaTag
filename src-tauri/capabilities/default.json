{
  "$schema": "https://schema.tauri.app/config/capabilities/2",
  "identifier": "default",
  "description": "Default capabilities for RetinaTag",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "dialog:allow-open",
    "dialog:allow-message",
    "dialog:allow-confirm",
    "dialog:allow-ask",
    "updater:default",
    "process:default",
    "process:allow-restart",
    "notification:default",
    "drag:default"
  ]
}
